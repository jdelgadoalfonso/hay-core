{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "outDir": "./dist",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "baseUrl": ".",
    "paths": {
      "@server/*": ["../../../server/*"]
    },
    "noImplicitAny": false,
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["src/router.ts"],
  "exclude": ["node_modules", "dist"]
}
