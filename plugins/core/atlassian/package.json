{
  "name": "hay-plugin-atlassian",
  "version": "0.2.0",
  "description": "Atlassian integration — import Confluence pages as documents and expose Jira tools to the agent via MCP",
  "author": "Hay",
  "license": "MIT",
  "main": "dist/index.js",
  "hay-plugin": {
    "entry": "./dist/index.js",
    "displayName": "Atlassian",
    "category": "document_importer",
    "autoActivate": true,
    "trpcRouter": "./src/router.ts",
    "capabilities": [
      "document_importer",
      "mcp",
      "auth"
    ],
    "env": [
      "ATLASSIAN_CLIENT_ID",
      "ATLASSIAN_CLIENT_SECRET"
    ],
    "config": {
      "authMode": {
        "type": "string",
        "label": "Auth method",
        "options": [
          {
            "label": "API Token (recommended)",
            "value": "basic"
          },
          {
            "label": "OAuth",
            "value": "oauth"
          }
        ],
        "default": "basic",
        "required": true
      },
      "siteUrl": {
        "type": "string",
        "label": "Atlassian site URL",
        "placeholder": "https://your-team.atlassian.net",
        "helpText": "Used for both Confluence and Jira access.",
        "required": true
      },
      "email": {
        "type": "string",
        "label": "Atlassian email",
        "placeholder": "you@example.com",
        "required": false,
        "helpText": "Required when Auth method is 'API Token'."
      },
      "apiToken": {
        "type": "string",
        "label": "API token",
        "encrypted": true,
        "required": false,
        "helpText": "Required when Auth method is 'API Token'. Works for both Confluence and Jira. Create one at id.atlassian.com/manage-profile/security/api-tokens"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js"
  },
  "keywords": [
    "atlassian",
    "confluence",
    "jira",
    "document-importer",
    "mcp"
  ],
  "dependencies": {
    "@hay/plugin-sdk": "file:../../../packages/plugin-sdk"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
