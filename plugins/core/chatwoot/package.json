{
  "name": "hay-channel-chatwoot",
  "version": "1.0.0",
  "description": "Connect Chatwoot as a communication channel — route conversations through Hay's AI orchestrator and escalate back to Chatwoot human agents",
  "author": "Hay",
  "type": "module",
  "main": "dist/index.js",
  "hay-plugin": {
    "entry": "./dist/index.js",
    "displayName": "Chatwoot",
    "category": "channel",
    "channel": "chatwoot",
    "capabilities": [
      "messages",
      "customers"
    ],
    "env": []
  },
  "scripts": {
    "build": "npm run build:ui && tsc",
    "build:ui": "vite build --config vite.config.ui.ts",
    "start": "node dist/index.js",
    "dev": "npm run build:ui && tsc",
    "dev:ui": "vite build --watch --config vite.config.ui.ts"
  },
  "dependencies": {
    "@hay/plugin-sdk": "file:../../../packages/plugin-sdk"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vue": "^3.4.0"
  }
}
