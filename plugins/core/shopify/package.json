{
  "name": "hay-plugin-shopify",
  "version": "1.0.0",
  "type": "module",
  "description": "Connect your Shopify store — Hay handles auth (managed OAuth or self-hosted), exposes Admin API tools via MCP, and syncs your catalog so the agent can recommend real products.",
  "author": "Hay",
  "main": "dist/index.js",
  "hay-plugin": {
    "entry": "./dist/index.js",
    "displayName": "Shopify",
    "category": "integration",
    "capabilities": [
      "mcp",
      "auth",
      "cron",
      "products"
    ],
    "env": [
      "SHOPIFY_OAUTH_CLIENT_ID",
      "SHOPIFY_OAUTH_CLIENT_SECRET"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@hay/plugin-sdk": "file:../../../packages/plugin-sdk"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0"
  }
}
