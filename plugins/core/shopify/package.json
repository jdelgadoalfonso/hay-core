{
  "name": "hay-plugin-shopify",
  "version": "1.0.0",
  "type": "module",
  "description": "Sync your Shopify catalog into Hay so the agent can recommend real products.",
  "author": "Hay",
  "main": "dist/index.js",
  "hay-plugin": {
    "entry": "./dist/index.js",
    "displayName": "Shopify",
    "category": "products",
    "capabilities": [
      "products",
      "auth",
      "config",
      "routes"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@hay/plugin-sdk": "file:../../../packages/plugin-sdk"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0"
  }
}
