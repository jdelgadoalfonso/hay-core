{
  "name": "hay-plugin-shopify",
  "version": "1.0.0",
  "type": "module",
  "description": "Connect your Shopify store (self-hosted Dev Dashboard app) — Hay handles the 24h access-token refresh automatically",
  "author": "Hay",
  "main": "dist/index.js",
  "hay-plugin": {
    "entry": "./dist/index.js",
    "displayName": "Shopify",
    "category": "integration",
    "capabilities": [
      "mcp",
      "auth",
      "cron"
    ],
    "env": [
      "SHOPIFY_OAUTH_CLIENT_ID",
      "SHOPIFY_OAUTH_CLIENT_SECRET"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@hay/plugin-sdk": "file:../../../packages/plugin-sdk"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.0"
  }
}
